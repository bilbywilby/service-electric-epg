# Copy this file to config/.env (gitignored) and fill it in for LOCAL
# runs of scripts/discover_lineup.py, a manual scripts/fetch_epg.py
# invocation, or wrapper.sh (which reads config/.env directly). This
# file is never read directly by Python -- for a manual script run,
# source it into your shell first:
#
#   set -a; source config/.env; set +a
#   python scripts/discover_lineup.py --postal-code 18101
#
# In GitHub Actions these same names are supplied as repository Secrets
# (SD_USERNAME, SD_PASSWORD) and Variables (SD_LINEUP_ID, DAYS_AHEAD) --
# see README.md "One-time setup".

SD_USERNAME=you@example.com
SD_PASSWORD=your-schedules-direct-password
SD_LINEUP_ID=USA-PAxxxxx-X
DAYS_AHEAD=10
